# .env.example — template das variaveis que o docker-compose.yml interpola via ${VAR}.
# Uso: copie para .env (cp .env.example .env) e preencha com valores reais.
# O .env real NAO e versionado; este .example contem apenas placeholders.
#
# A chave RSA de assinatura JWT NAO entra aqui: um PEM multilinha quebra o parsing
# do .env. Ela vive no docker-compose.override.yml (nao-versionado) como block
# scalar em environment:. Gere a chave com scripts/gen-rsa-key.sh e cole-a no
# override (template: docker-compose.override.example.yml).

# ---------- SQL Server (identity) ----------
SQLSERVER_SA_PASSWORD=ChangeMe_StrongP@ss123

# ---------- RabbitMQ ----------
RABBITMQ_USER=fcg
RABBITMQ_PASSWORD=ChangeMe_RabbitP@ss123

# ---------- Identity (aplicacao) ----------
# Use a MESMA senha de SQLSERVER_SA_PASSWORD no campo Password= abaixo.
# O .env nao expande ${VAR} dentro de outro valor: preencha a mao nos dois lugares.
IDENTITY_DB_CONNECTION=Server=sqlserver-identity;Database=identity;User Id=sa;Password=ChangeMe_StrongP@ss123;TrustServerCertificate=True
ADMINSEED_PASSWORD=ChangeMe_AdminP@ss123

# ---------- Servicos futuros (catalog / payments / notifications) ----------
